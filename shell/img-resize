#!/bin/bash

# Image batch resizing tool for iOS app screenshots
# Usage: img-resize <input_dir> [options]
# Options:
#   -d, --dimensions WxH    Target dimensions (e.g., 1242x2688)
#   -r, --reference DIR     Use reference directory dimensions
#   -o, --output-dir DIR   Output directory
#   -i, --interactive      Interactive mode with preset list
#   -q, --quiet            Suppress output
#   -h, --help            Show this help
#
# Interactive mode: img-resize -i /path/to/images

SCRIPT_DIR="$(cd "$(dirname "$0")/../media" && pwd)"
PYTHON_SCRIPT="$SCRIPT_DIR/resize_images.py"

exec python3 "$PYTHON_SCRIPT" "$@"