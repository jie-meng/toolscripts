#!/usr/bin/env bash

set -e
DIR=$(dirname "$0")

if [ $# -eq 0 ]; then
    echo "Usage: $0 <phrase...>"
    echo ""
    echo "Convert a phrase to a slug with interactive separator and case selection."
    echo ""
    echo "Example:"
    echo "  $0 App Store Connect Version Information"
    exit 1
fi

python3 "${DIR}/../document/slugify.py" "$@"
